{
    "name": "@necroloto/shared",
    "version": "0.0.0",
    "private": true,
    "type": "commonjs",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./scoring": {
            "types": "./dist/scoring.d.ts",
            "default": "./dist/scoring.js"
        },
        "./enums": {
            "types": "./dist/enums.d.ts",
            "default": "./dist/enums.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "test": "tsc -p tsconfig.json && node --test \"test/*.test.mjs\""
    },
    "devDependencies": {
        "typescript": "^5.7.3"
    }
}
