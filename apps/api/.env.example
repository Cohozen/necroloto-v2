# --- Database (Supabase) ---
# Runtime: transaction pooler (port 6543, pgbouncer). Used by the app at runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations: session pooler (port 5432). Used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- One-off data migration only (source DB) ---
# Neon connection string, consumed by scripts/migrate-data.mjs. Remove once migrated.
NEON_DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# --- Auth (Clerk) ---
# PEM public key used to verify Clerk session JWTs (Clerk dashboard > API keys > JWT public key).
CLERK_JWT_KEY=""
# Secret key, needed to read users' publicMetadata for admin role checks (Phase 3.4).
CLERK_SECRET_KEY=""

# --- Storage (Supabase) — Phase 2 ---
SUPABASE_URL="https://<ref>.supabase.co"
# Service role key (server-side only, never exposed to the client).
SUPABASE_SERVICE_ROLE_KEY=""

# --- Server ---
PORT=3000
# Comma-separated list of allowed CORS origins (web/mobile). Empty = allow all (dev).
FRONTEND_ORIGIN=""
