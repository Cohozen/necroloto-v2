generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum CircleStatus {
  OPEN
  LOCKED
  ARCHIVED
}

enum MembershipRole {
  ADMIN
  MEMBER
}

enum CircleVisibility {
  PRIVATE
  PUBLIC
}

enum SyncJobType {
  WIKIDATA_BULK_ENRICH
  DEATH_SCAN
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

/// Lifecycle of a celebrity entry. Admin-created rows are APPROVED; entries a
/// player proposes from the bet draft start PENDING and stay visible only to
/// their proposer until an admin approves them. REJECTED keeps the row so the
/// same Wikidata entity can't be re-proposed in a loop.
enum CelebrityStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Kind of in-app notification. Drives the icon/tone and the deep-link the web
/// renders. Populated asynchronously from domain events (see NotificationsService).
enum NotificationType {
  CELEBRITY_DEATH
  CIRCLE_NEW_MEMBER
  SEASON_BETS_OPEN
  SEASON_OPENED
  SEASON_CLOSED
  CELEBRITY_PROPOSAL_APPROVED
  CELEBRITY_PROPOSAL_REJECTED
  CELEBRITY_PROPOSAL_PENDING
  WELCOME
  SEASON_WINNER
  BET_CLOSING_SOON
}

/// Monotonic lifecycle milestone of a season, used as the cursor of the daily
/// season scheduler so each milestone fires its notification exactly once.
enum SeasonMilestone {
  BETS_OPEN
  SEASON_OPENED
  CLOSED
}

model User {
  id             String       @id @default(uuid())
  clerkId        String
  email          String?      @unique
  image          String?
  username       String?
  firstname      String?
  lastname       String?
  clerkCreatedAt DateTime     @default(now())
  clerkUpdatedAt DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Bets           Bet[]
  Membership     Membership[]
  notifications  Notification[]
}

/// In-app notification owned by a user. Created asynchronously by event handlers
/// (death of a bet pick, new circle member, season milestones). `data` carries
/// an optional deep-link payload ({ circleId?, celebrityId?, year? }).
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Celebrity {
  id               String             @id @default(uuid())
  name             String
  birth            DateTime?          @db.Date
  death            DateTime?          @db.Date
  photo            String?
  wikidataId       String?            @unique
  role             String?
  category         String?
  status           CelebrityStatus    @default(APPROVED)
  proposedBy       String?            // User.id of the proposer (null for admin/legacy rows)
  proposedAt       DateTime?          // null for admin/legacy rows
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  CelebritiesOnBet CelebritiesOnBet[]

  @@index([status])
}

model Bet {
  id               String             @id @default(uuid())
  userId           String
  circleId         String?
  year             Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id])
  Circle           Circle?            @relation(fields: [circleId], references: [id])
  CelebritiesOnBet CelebritiesOnBet[]

  @@unique([userId, circleId, year])
}

model CelebritiesOnBet {
  betId       String
  celebrityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  points      Float     @default(0)
  bet         Bet       @relation(fields: [betId], references: [id])
  celebrity   Celebrity @relation(fields: [celebrityId], references: [id])

  @@id([betId, celebrityId])
}

model Circle {
  id          String           @id @default(uuid())
  name        String
  visibility  CircleVisibility @default(PRIVATE)
  status      CircleStatus     @default(OPEN)
  code        String?
  allowNewBet Boolean
  allowEdit   Boolean          @default(false)
  betsVisible Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  memberships Membership[]
  bets        Bet[]
}

model Season {
  id           String   @id @default(uuid())
  year         Int      @unique
  name         String?
  openDate     DateTime
  betStartDate DateTime
  betEndDate   DateTime
  closeDate    DateTime
  /// Cursor of the daily season scheduler: the latest milestone already notified.
  notifiedMilestone SeasonMilestone?
  /// When the "betting closes soon" reminder was sent (once per season).
  betsClosingNotifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Background job tracking (in-process worker): bulk Wikidata enrichment and
/// the daily death scan. Lets the admin follow progress and history.
model SyncJob {
  id         String        @id @default(uuid())
  type       SyncJobType
  status     SyncJobStatus @default(PENDING)
  total      Int           @default(0)
  processed  Int           @default(0)
  succeeded  Int           @default(0)
  failed     Int           @default(0)
  payload    Json?         // e.g. { celebrityIds: [...] }
  result     Json?         // per-item errors / detected deaths
  error      String?       // fatal error if the whole job crashed
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([type, createdAt])
}

model Membership {
  id       String         @id @default(uuid())
  user     User           @relation(fields: [userId], references: [id])
  userId   String
  circle   Circle         @relation(fields: [circleId], references: [id])
  circleId String
  role     MembershipRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  @@unique([userId, circleId])
}
