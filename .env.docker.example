# Env for the docker-compose dev stack (api + web). Copy to `.env.docker`
# (gitignored) and fill the secrets. Values target the host's Supabase CLI stack
# via host.docker.internal — do NOT use 127.0.0.1 here (that's the container).
#
#   cp .env.docker.example .env.docker
#   # then paste SUPABASE_SECRET_KEY from `cd apps/api && supabase status`

# --- Database (local Supabase CLI Postgres, no pooler) ---
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# --- Storage (local Supabase CLI) ---
SUPABASE_URL=http://host.docker.internal:54321
# From `supabase status` (the service_role / secret key of the local stack).
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=images

# --- Auth (Clerk dev instance) ---
CLERK_JWT_KEY=
CLERK_SECRET_KEY=

# --- Server ---
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# --- Web (Vite, exposed to the browser bundle) ---
VITE_CLERK_PUBLISHABLE_KEY=
