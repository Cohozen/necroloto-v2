# Dev image shared by the `api` and `web` services in docker-compose.yml.
# Unlike the prod Dockerfile, it does NOT build the app: source is bind-mounted
# and each service runs in watch mode (NestJS start:dev / Vite). We only install
# the workspace dependencies here so node_modules lives inside the container
# (linux binaries), shadowing the host's macOS ones via anonymous volumes.
FROM node:22-bookworm-slim AS base
# openssl + ca-certificates are required by Prisma's engines.
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
ENV PNPM_HOME=/pnpm
ENV PATH=/pnpm:$PATH
RUN corepack enable
WORKDIR /app

# --- Install dependencies (cached on manifest changes) ---
COPY pnpm-workspace.yaml pnpm-lock.yaml .npmrc package.json turbo.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
RUN pnpm install --frozen-lockfile

# No CMD: the compose file provides a per-service command (api vs web).
EXPOSE 3000 5173
