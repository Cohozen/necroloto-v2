# Build context ignore for Dockerfile.dev (BuildKit reads <dockerfile>.dockerignore).
# Same as the root .dockerignore but KEEPS apps/web — the dev image installs the
# whole workspace (api + web + shared) so both services share one image.

# Reinstalled / regenerated inside the image
**/node_modules
**/dist
**/generated
**/.turbo

# Never copy local env files into the image
**/.env
**/.env.*

# VCS / editor / misc
.git
.idea
.vscode
**/*.log
.DS_Store

# Not part of the dev stack
apps/mobile
